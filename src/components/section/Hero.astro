---
import { getImage } from 'astro:assets';

import pcHero from '../../assets/images/pc-hero.png';
import tabHero from '../../assets/images/tab-hero.png';
import spHero from '../../assets/images/sp-hero.png';

const pc = await getImage({ src: pcHero, format: 'webp' });
const tab = await getImage({ src: tabHero, format: 'webp' });
const sp = await getImage({ src: spHero, format: 'webp' });
---
<section class="hero" data-hero>
    <picture class="hero-picture">
      <source media="(max-width: 500px)" srcset={sp.src} />
      <source media="(max-width: 768px)" srcset={tab.src} />
      <img
        src={pc.src}
        alt="湘南・片瀬海岸のフレックス湘南"
        data-hero-image
      />
    </picture>
    <p class="hero-text">
      <span class="hero-text-line line1" data-hero-line>整える。</span>
      <span class="hero-text-line line2" data-hero-line>鍛える。</span>
      <span class="hero-text-line line3" data-hero-line>焼く。</span>
    </p>
    <div class="hero-waves" aria-hidden="true" data-hero-waves>
      <svg
        class="waves"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 24 150 28"
        preserveAspectRatio="none"
        shape-rendering="auto"
      >
        <defs>
          <path
            id="gentle-wave"
            d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z"
          />
        </defs>
        <g class="wave-parallax">
          <use href="#gentle-wave" x="48" y="0" fill="rgba(255,255,255,0.7)" />
          <use href="#gentle-wave" x="48" y="3" fill="rgba(255,255,255,0.5)" />
          <use href="#gentle-wave" x="48" y="5" fill="rgba(255,255,255,0.3)" />
          <use href="#gentle-wave" x="48" y="7" fill="#ffffff" />
        </g>
      </svg>
    </div>
</section>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .hero {
    position: relative; 
    width: 100%;
    height: 100dvh;
    overflow: hidden;
  }

  .hero-picture {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hero-picture img {
    will-change: transform;
  }

  .hero-text {
    position: absolute;
    display: flex;
    flex-direction: column;
    top: 50%;
    right: clamp(20px, 6vw, 100px);
    gap: 0.3em;
    color: #fff;
    font-weight: bold;
    font-size: clamp(4rem, 5vw, 5rem);
    line-height: 1.2;
    letter-spacing: 0.1em;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    z-index: 2;
    transform: translateY(-30%) rotate(-12deg);
    transform-origin: center;

    @include sp {
      top: 60%;
      right: 20px;
      font-size: clamp(3rem, 8vw, 4rem);
    }
  }

  .hero-text-line {
    display: block;
  }

  .line2 { margin-left: 1.2em; }
  .line3 { margin-left: 2.4em; }

  .hero-waves {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    line-height: 0;
  }

  .waves {
    display: block;
    width: 100%;
    height: 100px;
  }

  // 4枚を別々の速度で動かして「波打つ」感じを出す
  .wave-parallax > use {
    animation: wave-move 25s cubic-bezier(0.55, 0.5, 0.45, 0.5) infinite;
  }
  .wave-parallax > use:nth-child(1) { animation-delay: -2s; animation-duration:  7s; }
  .wave-parallax > use:nth-child(2) { animation-delay: -3s; animation-duration: 10s; }
  .wave-parallax > use:nth-child(3) { animation-delay: -4s; animation-duration: 13s; }
  .wave-parallax > use:nth-child(4) { animation-delay: -5s; animation-duration: 20s; }

  @keyframes wave-move {
    0%   { transform: translate3d(-90px, 0, 0); }
    100% { transform: translate3d( 85px, 0, 0); }
  }

  @media (max-width: 768px) {
    .waves { height: 60px; }
  }
  @media (max-width: 500px) {
    .waves { height: 40px; }
  }

  /* アクセシビリティ / アニメ抑制設定 */
  @media (prefers-reduced-motion: reduce) {
    .wave-parallax > use { animation: none; }
  }
</style>